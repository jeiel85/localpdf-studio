# Maintainer: Aiden Park <jeiel85@gmail.com>

pkgname=localpdf-studio-bin
_pkgname=localpdf-studio
pkgver=0.17.2
pkgrel=1
pkgdesc="Local-first desktop PDF viewer and utility suite (Tauri 2 + React)"
arch=('x86_64')
url="https://github.com/jeiel85/localpdf-studio"
license=('Apache-2.0')
depends=('webkit2gtk-4.1' 'gtk3' 'libayatana-appindicator')
optdepends=(
  'qpdf: PDF manipulation (auto-installed if missing)'
  'tesseract: OCR support (auto-installed if missing)'
  'tesseract-data-kor: Korean OCR'
  'tesseract-data-eng: English OCR'
)
provides=("$_pkgname")
conflicts=("$_pkgname")

source_x86_64=("$_pkgname-$pkgver-x86_64.deb::https://github.com/jeiel85/localpdf-studio/releases/download/v$pkgver/LocalPDF.Studio_${pkgver}_amd64.deb")
sha256sums_x86_64=('fbae2f57cb221d15eedacefec29aad9cd0e2fabf008982f67c5a8e6afec9aa72')

package() {
  cd "$srcdir"
  bsdtar -O -xf "$_pkgname-$pkgver-x86_64.deb" data.tar.gz | bsdtar -C "$pkgdir" -xzf -
  # 또는 ar 사용 가능:
  # ar x "$_pkgname-$pkgver-x86_64.deb"
  # tar -C "$pkgdir" -xf data.tar.gz

  # ELF 권한 정리
  find "$pkgdir" -type f -name "*.so*" -exec chmod 644 {} \;

  # 라이센스
  install -Dm644 "$pkgdir/usr/share/doc/$_pkgname/copyright" \
    "$pkgdir/usr/share/licenses/$pkgname/LICENSE" 2>/dev/null || true
}
