{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "LocalPDF Studio",
  "version": "0.17.2",
  "identifier": "com.jeiel85.localpdfstudio",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://127.0.0.1:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "LocalPDF Studio",
        "width": 1280,
        "height": 820,
        "minWidth": 980,
        "minHeight": 680,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self' 'wasm-unsafe-eval'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob: pdf-local: ipc: https://ipc.localhost; font-src 'self' data:; connect-src 'self' ipc: pdf-local: https://ipc.localhost https://github.com https://*.githubusercontent.com; worker-src 'self' blob:; object-src 'none'; frame-ancestors 'none'"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "msi", "deb", "rpm", "appimage", "dmg", "app"],
    "category": "Productivity",
    "copyright": "Copyright © 2026 Aiden Park",
    "shortDescription": "Local-first desktop PDF studio",
    "longDescription": "LocalPDF Studio is a desktop PDF viewer and utility suite designed for local-first PDF workflows.",
    "createUpdaterArtifacts": true,
    "homepage": "https://jeiel85.github.io/localpdf-studio/",
    "publisher": "Aiden Park",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico",
      "icons/icon.png"
    ],
    "windows": {
      "nsis": {
        "displayLanguageSelector": true,
        "installMode": "currentUser",
        "installerHooks": "./windows/nsis-hooks.nsh"
      },
      "wix": {
        "language": ["ko-KR", "en-US"]
      }
    },
    "linux": {
      "deb": {
        "depends": ["libwebkit2gtk-4.1-0", "libgtk-3-0"],
        "section": "graphics"
      },
      "rpm": {
        "depends": ["webkit2gtk4.1", "gtk3"],
        "release": "1"
      },
      "appimage": {
        "bundleMediaFramework": true
      }
    },
    "macOS": {
      "minimumSystemVersion": "10.15",
      "exceptionDomain": "",
      "frameworks": []
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDZENEEyRkFDN0Y5MzdGRTYKUldUbWY1Ti9yQzlLYlU4cS8wVER4c3F1UlE2TVhnaWNvSTNtZXRleU8zUmRCV1lNb28xYklOaC8K",
      "endpoints": [
        "https://github.com/jeiel85/localpdf-studio/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
